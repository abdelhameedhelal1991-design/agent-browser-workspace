{
  "id": "x-twitter",
  "name": "X / Twitter",
  "hosts": [
    "x.com",
    "www.x.com",
    "twitter.com",
    "www.twitter.com",
    "mobile.x.com",
    "mobile.twitter.com"
  ],
  "baseUrl": "https://x.com",
  "scraping": {
    "selectors": {
      "tweetArticle": "article",
      "tweetText": "[data-testid=\"tweetText\"]",
      "tweetTime": "time",
      "tweetLink": "a[href*=\"/status/\"]"
    },
    "xTwitter": {
      "defaultScroll": {
        "times": 12,
        "delay": 2500
      }
    }
  },
  "controls": {
    "items": [
      {
        "name": "Твиты / посты",
        "selectorKey": "tweetArticle",
        "description": "Карточки постов в ленте профиля или треда на X.",
        "actions": [
          "scroll:times=12,delay=2500",
          "readText"
        ]
      }
    ]
  }
}
